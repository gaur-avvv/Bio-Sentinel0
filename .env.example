# Hugging Face token with access to required model repos.
HF_TOKEN=replace_with_your_token

# Optional Gemini API key if you integrate Gemini-backed workflows.
GEMINI_API_KEY=replace_with_your_key

# Comma-separated allowed CORS origins for browser apps (Vercel + local).
# Example: https://my-app.vercel.app,http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
