# Hugging Face token with access to required model repos.
HF_TOKEN=replace_with_your_token

# Optional Gemini API key if you integrate Gemini-backed workflows.
GEMINI_API_KEY=replace_with_your_key

# Optional direct Postgres connection string for Railway or Supabase Postgres.
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=replace_with_your_database_url

# Optional Supabase API settings for storage-backed reads and writes.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=replace_with_your_service_role_key
SUPABASE_RECORDS_TABLE=encounters
SUPABASE_ALERTS_TABLE=alerts
SUPABASE_WRITE_THROUGH=false

# Optional Railway Postgres overrides.
RAILWAY_DATABASE_URL=replace_with_your_railway_database_url
RAILWAY_RECORDS_TABLE=encounters
RAILWAY_ALERTS_TABLE=alerts
RAILWAY_WRITE_THROUGH=false

# Backend selection for /records, /records/{record_id}, and /alerts.
READ_BACKEND=sqlite

# Comma-separated allowed CORS origins for browser apps (Vercel + local).
# Example: https://my-app.vercel.app,http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
